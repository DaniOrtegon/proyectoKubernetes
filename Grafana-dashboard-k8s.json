{
  "title": "WordPress K8s - Project Dashboard",
  "uid": "wordpress-k8s-project",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "custom",
        "label": "Namespace",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          {"text": "All", "value": "$__all", "selected": true},
          {"text": "wordpress", "value": "wordpress"},
          {"text": "databases", "value": "databases"},
          {"text": "monitoring", "value": "monitoring"},
          {"text": "security", "value": "security"}
        ],
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Pods Running",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "count(kube_pod_status_phase{phase=\"Running\"})",
        "legendFormat": "Running"
      }]
    },
    {
      "id": 2,
      "title": "🔴 Pods con Problemas",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "count(kube_pod_status_phase{phase!~\"Running|Succeeded\"}) or vector(0)",
        "legendFormat": "Con problemas"
      }]
    },
    {
      "id": 3,
      "title": "🔄 Reinicios de Pods (última hora)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "sum(increase(kube_pod_container_status_restarts_total[1h])) or vector(0)",
        "legendFormat": "Reinicios"
      }]
    },
    {
      "id": 4,
      "title": "💻 CPU Total del Clúster",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.6},
              {"color": "red", "value": 0.8}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m])) / sum(machine_cpu_cores)",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 5,
      "title": "🧠 Memoria Total del Clúster",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.6},
              {"color": "red", "value": 0.8}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) / sum(machine_memory_bytes)",
        "legendFormat": "Memoria %"
      }]
    },
    {
      "id": 6,
      "title": "📦 Total Namespaces activos",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"steps": [{"color": "blue", "value": 0}]},
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "count(count(kube_pod_status_phase{phase=\"Running\"}) by (namespace))",
        "legendFormat": "Namespaces"
      }]
    },
    {
      "id": 10,
      "title": "📋 Estado de todos los Pods",
      "type": "table",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 4},
      "options": {
        "sortBy": [{"displayName": "Namespace"}],
        "footer": {"show": false}
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "phase"},
            "properties": [{
              "id": "custom.displayMode",
              "value": "color-background"
            },{
              "id": "thresholds",
              "value": {
                "steps": [
                  {"color": "green", "value": null}
                ]
              }
            },{
              "id": "mappings",
              "value": [
                {"type": "value", "options": {"Running": {"color": "green", "text": "✅ Running"}}},
                {"type": "value", "options": {"Pending": {"color": "yellow", "text": "⏳ Pending"}}},
                {"type": "value", "options": {"Failed": {"color": "red", "text": "❌ Failed"}}},
                {"type": "value", "options": {"CrashLoopBackOff": {"color": "red", "text": "🔴 CrashLoop"}}}
              ]
            }]
          }
        ]
      },
      "targets": [{
        "expr": "kube_pod_status_phase",
        "instant": true,
        "legendFormat": "",
        "format": "table"
      }],
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["namespace", "pod", "phase", "Value"]}}},
        {"id": "filterByValue", "options": {"filters": [{"fieldName": "Value", "config": {"id": "greater", "options": {"value": 0}}}]}}
      ]
    },
    {
      "id": 20,
      "title": "🖥️ CPU por Namespace",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[5m])) by (namespace)",
        "legendFormat": "{{namespace}}"
      }]
    },
    {
      "id": 21,
      "title": "🧠 Memoria por Namespace",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) by (namespace)",
        "legendFormat": "{{namespace}}"
      }]
    },
    {
      "id": 30,
      "title": "🌐 WordPress",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "collapsed": false
    },
    {
      "id": 31,
      "title": "WordPress - CPU",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 23},
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "color": {"fixedColor": "#5794F2", "mode": "fixed"}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"wordpress\", container!=\"\", container!=\"POD\"}[5m])) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 32,
      "title": "WordPress - Memoria",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 23},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "color": {"fixedColor": "#5794F2", "mode": "fixed"}
        }
      },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=\"wordpress\", container!=\"\", container!=\"POD\"}) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 33,
      "title": "WordPress - Reinicios",
      "type": "stat",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 23},
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 3}
            ]
          },
          "color": {"mode": "thresholds"}
        }
      },
      "targets": [{
        "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"wordpress\"}[1h])) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 40,
      "title": "🗄️ Bases de Datos",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 30},
      "collapsed": false
    },
    {
      "id": 41,
      "title": "MariaDB - CPU",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 31},
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "color": {"fixedColor": "#FF9830", "mode": "fixed"}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"databases\", container=\"mariadb\"}[5m])) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 42,
      "title": "MariaDB - Memoria",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 31},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "color": {"fixedColor": "#FF9830", "mode": "fixed"}
        }
      },
      "targets": [{
        "expr": "sum(container_memory_working_set_bytes{namespace=\"databases\", container=\"mariadb\"}) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 43,
      "title": "Redis - CPU",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 31},
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "color": {"fixedColor": "#E02F44", "mode": "fixed"}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"databases\", container=\"redis\"}[5m])) by (pod)",
        "legendFormat": "{{pod}}"
      }]
    },
    {
      "id": 50,
      "title": "📊 Red",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "collapsed": false
    },
    {
      "id": 51,
      "title": "Red - Tráfico entrante por Namespace",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 39},
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_network_receive_bytes_total{namespace=~\"wordpress|databases|monitoring\"}[5m])) by (namespace)",
        "legendFormat": "↓ {{namespace}}"
      }]
    },
    {
      "id": 52,
      "title": "Red - Tráfico saliente por Namespace",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 39},
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "targets": [{
        "expr": "sum(rate(container_network_transmit_bytes_total{namespace=~\"wordpress|databases|monitoring\"}[5m])) by (namespace)",
        "legendFormat": "↑ {{namespace}}"
      }]
    },
    {
      "id": 60,
      "title": "💾 Almacenamiento",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 46},
      "collapsed": false
    },
    {
      "id": 61,
      "title": "PVCs - Uso de almacenamiento",
      "type": "bargauge",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 47},
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          },
          "color": {"mode": "thresholds"},
          "min": 0,
          "max": 1
        }
      },
      "targets": [{
        "expr": "kubelet_volume_stats_used_bytes / kubelet_volume_stats_capacity_bytes",
        "legendFormat": "{{persistentvolumeclaim}}"
      }]
    },
    {
      "id": 62,
      "title": "PVCs - Espacio usado vs disponible",
      "type": "table",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 47},
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Usado"}, "properties": [{"id": "unit", "value": "bytes"}]},
          {"matcher": {"id": "byName", "options": "Capacidad"}, "properties": [{"id": "unit", "value": "bytes"}]}
        ]
      },
      "targets": [
        {
          "expr": "kubelet_volume_stats_used_bytes",
          "legendFormat": "{{persistentvolumeclaim}}",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "id": 70,
      "title": "🚨 Alertas",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 54},
      "collapsed": false
    },
    {
      "id": 71,
      "title": "Pods con problemas de imagen",
      "type": "table",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 55},
      "fieldConfig": {"defaults": {}},
      "targets": [{
        "expr": "kube_pod_container_status_waiting_reason{reason=~\"ErrImagePull|ImagePullBackOff|CrashLoopBackOff|OOMKilled\"} == 1",
        "instant": true,
        "format": "table",
        "legendFormat": ""
      }],
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["namespace", "pod", "container", "reason"]}}}
      ]
    },
    {
      "id": 72,
      "title": "Pods no programados",
      "type": "table",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 55},
      "fieldConfig": {"defaults": {}},
      "targets": [{
        "expr": "kube_pod_status_scheduled{condition=\"false\"} == 1",
        "instant": true,
        "format": "table",
        "legendFormat": ""
      }],
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["namespace", "pod", "condition"]}}}
      ]
    }
  ]
}
